# ===================== 核心架构与设备匹配（必选） =====================
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
CONFIG_TARGET_rockchip_armv8_DEVICE_huake-cloud_guangmiao-g4c=y
CONFIG_TARGET_BOARD="rockchip"
CONFIG_TARGET_SUBTARGET="armv8"
CONFIG_ARCH_64BIT=y
CONFIG_CPU_TYPE="cortex-a53+cortex-a72"  # RK3399 核心架构
CONFIG_LINUX_VERSION="6.6.30"
