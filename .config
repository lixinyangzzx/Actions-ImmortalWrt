# ===================== 核心架构/设备树配置（关键） =====================
CONFIG_TARGET_rockchip=y
CONFIG_TARGET_rockchip_armv8=y
# 精准匹配设备树：rk3399-guangmiao-g4c.dts
CONFIG_TARGET_rockchip_armv8_DEVICE_huake-cloud_guangmiao-g4c=y
CONFIG_TARGET_BOARD="rockchip"
CONFIG_TARGET_SUBTARGET="armv8"
CONFIG_ARCH_64BIT=y
CONFIG_CPU_TYPE="cortex-a53+cortex-a72"  # RK3399 双核A72+四核A53
CONFIG_LINUX_VERSION="6.1.60"  # 适配 ImmortalWrt master 最新内核

# ===================== 文件系统配置 =====================
CONFIG_TARGET_ROOTFS_EXT4=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_ROOTFS_SQUASHFS_COMPRESSION_ZSTD=y  # 压缩率/性能更优
CONFIG_TARGET_ROOTFS_PARTSIZE=4096  # 根分区4G（适配G4C的eMMC/存储）
CONFIG_TARGET_USES_INITRAMFS=y
CONFIG_TARGET_INITRAMFS_COMPRESSION_GZIP=y
CONFIG_TARGET_IMAGES_GZIP=y  # 固件镜像压缩
