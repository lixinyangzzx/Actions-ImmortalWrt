# 核心基础包（ImmortalWrt 官方源，匹配 master 分支）
src-git packages https://github.com/immortalwrt/packages.git;master
src-git luci https://github.com/immortalwrt/luci.git;master
src-git routing https://github.com/openwrt/routing.git;master
src-git telephony https://github.com/openwrt/telephony.git;master

# 可选：补充常用插件源（适配 64 位 ARMv8/RK3399）
src-git small https://github.com/kenzok8/small.git;master
src-git small8 https://github.com/kenzok8/small-package.git;master
src-git openclash https://github.com/vernesong/OpenClash.git;master  # 热门代理插件
